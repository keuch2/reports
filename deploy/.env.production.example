# Mister Co. Reports — variables de entorno PRODUCCIÓN
# Copialo a /var/www/reports/.env y completá los valores.
# Permisos recomendados: chmod 640 .env && chown www-data:www-data .env
# ----------------------------------------------------------------------------

APP_NAME="Mister Co. Reports"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://reports.mister.com.py

# Generar con:  php bin/generate-key.php  (o `php -r "echo 'base64:'.base64_encode(random_bytes(32));"`)
# IMPORTANTE: rotar este valor invalida todos los tokens cifrados en BD (Meta, 2FA).
APP_KEY=

# ===== Base de datos =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=misterco_reports
DB_USERNAME=misterco
DB_PASSWORD=                # crear usuario MySQL dedicado, no usar root

# ===== Meta Marketing API =====
# Business Manager principal de Mister Co.
META_BUSINESS_MANAGER_ID=10152846879291613
META_API_VERSION=v20.0
# El token vive cifrado en la BD (tabla `configuracion`). Lo pegás desde
# /admin/meta tras el primer login. Esta variable queda vacía en producción.
META_SYSTEM_USER_TOKEN=

# ===== SMTP (recuperación de contraseña) =====
# Si dejás SMTP_HOST vacío, los correos se loguean a storage/logs/php-*.log
# en vez de enviarse (útil para staging).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@mister.com.py
SMTP_FROM_NAME="Mister Co. Reports"

# ===== Sesión =====
SESSION_LIFETIME_MINUTES=120
SESSION_SECURE_COOKIE=true   # exige HTTPS — sólo desactivar en local

# ===== Logs =====
LOG_LEVEL=warning            # debug | info | warning | error
